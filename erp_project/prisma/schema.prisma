  rm_vrm_dynamic rm_vrm_dynamic[]

  @@index([status, name], map: "idx_master_rm_status_name")
  @@index([status, make], map: "idx_master_rm_status_make")
  @@index([status, type], map: "idx_master_rm_status_type")
}

model master_skus {
