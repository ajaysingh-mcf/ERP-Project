  @@index([bom_id], map: "fk_mci_bom")
  @@index([created_by], map: "fk_mci_creator")
  @@index([mfg_id], map: "fk_mci_mfg")
  @@index([sku_id], map: "fk_mci_sku")
}

model master_mfgs {
  id                      Int                       @id @default(autoincrement())
  name                    String                    @db.VarChar(200)
  code                    String                    @unique(map: "code") @db.VarChar(50)
  bom_misc                bom_misc[]
  details_mfg             details_mfg[]
  master_bom_mfg          master_bom_mfg[]
  master_cost_ext_fixed   master_cost_ext_fixed[]
  master_cost_int_dynamic master_cost_int_dynamic[]
  pm_mrm_fixed            pm_mrm_fixed[]
  purchase_orders         purchase_orders[]
  rm_mrm_fixed            rm_mrm_fixed[]
}

model master_pm {
  id             Int               @id @default(autoincrement())
  name           String            @db.VarChar(200)
  type           String?           @db.VarChar(200)
  hsn_code       String?           @db.VarChar(20)
  pantone_color  String?           @db.VarChar(50)
  uom            String?           @db.VarChar(20)
