model pm_mrm_fixed {
  id             Int                 @id @default(autoincrement())
  pm_id          Int
  pm_code        String?             @db.VarChar(50)
  mfg_id         Int
  mfg_code       String?             @db.VarChar(50)
  curr_rate      Decimal             @db.Decimal(12, 4)
  effective_from DateTime            @db.Date
  updated_on     DateTime?           @default(now()) @db.Timestamp(0)
  uom            String?             @db.VarChar(20)
  status         pm_mrm_fixed_status @default(draft)
  effective_to   DateTime?           @db.Date
  master_pm      master_pm           @relation(fields: [pm_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "pm_mrm_fixed_ibfk_1")
  master_mfgs    master_mfgs         @relation(fields: [mfg_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "pm_mrm_fixed_ibfk_2")

  @@index([mfg_id], map: "mfg_id")
  @@index([pm_id], map: "pm_id")
  @@index([status, effective_from], map: "idx_pm_mrm_status_eff")
  @@index([status, curr_rate], map: "idx_pm_mrm_status_rate")
}

