  id                        Int                         @id @default(autoincrement())
  cost_code                 String                      @db.VarChar(100)
  bom_id                    Int
  mfg_id                    Int
  sku_id                    Int
  total_rm_cost             Decimal?                    @db.Decimal(12, 4)
