  master_skus            master_skus              @relation(fields: [sku_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_mce_sku")

  @@index([bom_id], map: "fk_mce_bom")
  @@index([created_by], map: "fk_mce_creator")
  @@index([mfg_id], map: "fk_mce_mfg")
  @@index([sku_id], map: "fk_mce_sku")
}

