generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model approval_items {
  id          Int       @id @default(autoincrement())
  approval_id Int
  field_name  String?   @db.VarChar(100)
  old_value   String?   @db.Text
  new_value   String?   @db.Text
  approvals   approvals @relation(fields: [approval_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "approval_items_ibfk_1")

  @@index([approval_id], map: "approval_id")
}

model approvals {
  id                                 Int               @id @default(autoincrement())
  raised_by                          Int
  raised_on                          DateTime?         @default(now()) @db.Timestamp(0)
  status                             approvals_status? @default(pending)
  remarks                            String?           @db.Text
  approved_by                        Int?
  approved_on                        DateTime?         @db.Timestamp(0)
  approval_type                      String?           @db.VarChar(100)
  module                             String?           @db.VarChar(50)
  entity_id                          Int?
  approval_items                     approval_items[]
  users_approvals_raised_byTousers   users             @relation("approvals_raised_byTousers", fields: [raised_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "approvals_ibfk_1")
  users_approvals_approved_byTousers users?            @relation("approvals_approved_byTousers", fields: [approved_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "approvals_ibfk_2")

  @@index([approved_by], map: "approved_by")
  @@index([raised_by], map: "raised_by")
}

model bom_misc {
  id             Int              @id @default(autoincrement())
  bom_id         Int
  mfg_id         Int
  type           bom_misc_type
  cost           Decimal?         @db.Decimal(12, 4)
  effective_from DateTime?        @db.Date
  effective_till DateTime?        @db.Date
  last_updated   DateTime?        @default(now()) @db.Timestamp(0)
  status         bom_misc_status? @default(active)
  bom            master_bom       @relation(fields: [bom_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "bom_misc_ibfk_1")
  mfgs           master_mfgs      @relation(fields: [mfg_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "bom_misc_ibfk_2")

  @@index([bom_id], map: "bom_id")
  @@index([mfg_id], map: "mfg_id")
}

model purchase_orders {
  id             Int                     @id @default(autoincrement())
  po_no          String                  @unique(map: "po_no") @db.VarChar(50)
  mfg_id         Int
  date           DateTime                @db.Date
  sku_code       String?                 @db.VarChar(50)
  bom_id         Int?
  qty            Decimal                 @db.Decimal(12, 3)
  unit_price     Decimal?                @db.Decimal(12, 4)
  total_amount   Decimal?                @db.Decimal(14, 4)
  expected_on    DateTime?               @db.Date
  received_qty   Decimal?                @default(0.000) @db.Decimal(12, 3)
  invoice_no     String?                 @db.VarChar(100)
  destination    String?                 @db.VarChar(100)
  status         purchase_orders_status? @default(draft)
  attachment_key String?                 @db.Text
  po_type        purchase_orders_type?   @default(impromptu)
  csv_source_key String?                 @db.VarChar(500)
  email_sent_at  DateTime?               @db.DateTime(0)
  mfgs           master_mfgs             @relation(fields: [mfg_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "purchase_orders_ibfk_1")
  bom            master_bom?             @relation(fields: [bom_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "purchase_orders_ibfk_2")

  @@index([bom_id], map: "bom_id")
  @@index([mfg_id], map: "mfg_id")
}

model session_history {
  id         Int                   @id @default(autoincrement())
  session_id String                @db.VarChar(36)
  user_id    Int
  event      session_history_event
  ip_address String?               @db.VarChar(45)
  user_agent String?               @db.Text
  event_at   DateTime?             @default(now()) @db.Timestamp(0)
  remarks    String?               @db.VarChar(200)
  users      users                 @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "session_history_ibfk_1")

  @@index([user_id], map: "user_id")
}

model sessions {
  id          Int                   @id @default(autoincrement())
  session_id  String                @unique(map: "session_id") @db.VarChar(36)
  user_id     Int
  token       String                @db.Text
  ip_address  String?               @db.VarChar(45)
  user_agent  String?               @db.Text
  device_type sessions_device_type? @default(web)
  created_at  DateTime?             @default(now()) @db.Timestamp(0)
  last_active DateTime?             @default(now()) @db.Timestamp(0)
  expires_at  DateTime              @db.Timestamp(0)
  is_active   Boolean?              @default(true)
  users       users                 @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sessions_ibfk_1")

  @@index([user_id], map: "user_id")
}

model sku_variants {
  id                                     Int         @id @default(autoincrement())
  parent_sku_id                          Int
  variant_sku_id                         Int
  sku_code                               String?     @db.VarChar(50)
  size                                   String?     @db.VarChar(50)
  created_at                             DateTime?   @default(now()) @db.Timestamp(0)
  skus_sku_variants_parent_sku_idToskus  master_skus @relation("sku_variants_parent_sku_idToskus", fields: [parent_sku_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sku_variants_ibfk_1")
  skus_sku_variants_variant_sku_idToskus master_skus @relation("sku_variants_variant_sku_idToskus", fields: [variant_sku_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "sku_variants_ibfk_2")

  @@unique([parent_sku_id, variant_sku_id], map: "parent_sku_id")
  @@index([variant_sku_id], map: "variant_sku_id")
}

model user_roles {
  user_id Int
  role    String @db.VarChar(100)

  @@id([user_id, role])
}

model page_permissions {
  id           Int                     @id @default(autoincrement())
  role         String                  @db.VarChar(100)
  page_slug    String                  @db.VarChar(100)
  access_level page_permissions_access @default(none)
  created_at   DateTime?               @default(now()) @db.Timestamp(0)

  @@unique([role, page_slug], map: "role_page_slug")
  @@index([role], map: "role")
}

model user_page_permissions {
  id           Int                     @id @default(autoincrement())
  user_id      Int
  page_slug    String                  @db.VarChar(100)
  access_level page_permissions_access
  created_at   DateTime?               @default(now()) @db.Timestamp(0)

  @@unique([user_id, page_slug], map: "user_id_page_slug")
  @@index([user_id], map: "user_id")
}

model users {
  id                                     Int                       @id @default(autoincrement())
  name                                   String                    @db.VarChar(100)
  email                                  String                    @unique(map: "email") @db.VarChar(100)
  status                                 users_status?             @default(active)
  created_at                             DateTime?                 @default(now()) @db.Timestamp(0)
  google_id                              String?                   @db.VarChar(255)
  approvals_approvals_raised_byTousers   approvals[]               @relation("approvals_raised_byTousers")
  approvals_approvals_approved_byTousers approvals[]               @relation("approvals_approved_byTousers")
  bom_artifacts                          bom_artifacts[]
  master_bom                             master_bom[]
  master_bom_mfg                         master_bom_mfg[]
  master_cost_ext_fixed                  master_cost_ext_fixed[]
  master_cost_int_dynamic                master_cost_int_dynamic[]
  master_skus                            master_skus[]
  master_vendors                         master_vendors[]
  session_history                        session_history[]
  sessions                               sessions[]
}

model details_bom {
  id                        Int                         @id @default(autoincrement())
  bom_id                    Int
  mtrl_type                 details_bom_mtrl_type
  mtrl_id                   Int
  amount                    Decimal                     @db.Decimal(12, 4)
  uom                       String?                     @db.VarChar(20)
  effective_from            DateTime?                   @db.Date
  effective_till            DateTime?                   @db.Date
  last_updated              DateTime?                   @default(now()) @db.Timestamp(0)
  status                    details_bom_status?         @default(active)
  updated_by                Int?
  master_bom                master_bom                  @relation(fields: [bom_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "details_bom_ibfk_1")
  details_cost__int_dynamic details_cost__int_dynamic[]
  details_cost_ext_fixed    details_cost_ext_fixed[]

  @@index([bom_id], map: "bom_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model details_cost__int_dynamic {
  id                      Int                                 @id @default(autoincrement())
  cost_id                 Int
  bom_detail_id           Int
  mtrl_type               details_cost__int_dynamic_mtrl_type
  mtrl_id                 Int
  qty                     Decimal                             @db.Decimal(10, 3)
  uom                     String                              @db.VarChar(20)
  rate                    Decimal                             @db.Decimal(12, 4)
  rm_vrm_id               Int
  pm_vrm_id               Int
  line_cost               Decimal?                            @db.Decimal(12, 4)
  details_bom             details_bom                         @relation(fields: [bom_detail_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_dci_bomdet")
  master_cost_int_dynamic master_cost_int_dynamic             @relation(fields: [cost_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_dci_cost")
  rm_vrm_dynamic          rm_vrm_dynamic                      @relation(fields: [rm_vrm_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_dci_rmvrm")

  @@index([bom_detail_id], map: "fk_dci_bomdet")
  @@index([cost_id], map: "fk_dci_cost")
  @@index([rm_vrm_id], map: "fk_dci_rmvrm")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model details_cost_ext_fixed {
  id                    Int                              @id @default(autoincrement())
  cost_id               Int
  bom_detail_id         Int
  mtrl_type             details_cost_ext_fixed_mtrl_type
  mtrl_id               Int
  qty                   Decimal                          @db.Decimal(10, 3)
  uom                   String                           @db.VarChar(20)
  rate                  Decimal                          @db.Decimal(12, 4)
  rm_mrm_id             Int?
  pm_mrm_id             Int?
  line_cost             Decimal?                         @db.Decimal(12, 4)
  details_bom           details_bom                      @relation(fields: [bom_detail_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_dce_bomdet")
  master_cost_ext_fixed master_cost_ext_fixed            @relation(fields: [cost_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_dce_cost")
  rm_mrm_fixed          rm_mrm_fixed?                    @relation(fields: [rm_mrm_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_dci_rmmrm")

  @@index([bom_detail_id], map: "fk_dce_bomdet")
  @@index([cost_id], map: "fk_dce_cost")
  @@index([rm_mrm_id], map: "fk_dci_rmmrm")
}

model details_mfg {
  id                   Int                 @id @default(autoincrement())
  mfg_id               Int
  location             String?             @db.VarChar(200)
  gst_number           String?             @db.VarChar(20)
  status               details_mfg_status? @default(active)
  registered_name      String?             @db.VarChar(255)
  zone                 String?             @db.VarChar(100)
  bank_name            String?             @db.VarChar(255)
  ifsc_number          String?             @db.VarChar(11)
  account_number       String?             @db.VarChar(50)
  email                String?             @db.VarChar(255)
  gst_certificate_key  String?             @db.Text
  cancelled_cheque_key String?             @db.Text
  pan_card_key         String?             @db.Text
  misc_document_key    String?             @db.Text
  master_mfgs          master_mfgs         @relation(fields: [mfg_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "details_mfg_ibfk_1")

  @@index([mfg_id], map: "mfg_id")
}

model details_sku {
  id           Int                      @id @default(autoincrement())
  sku_id       Int                      @unique(map: "sku_id")
  sku_type     String                   @db.VarChar(100)
  demand_type  details_sku_demand_type?
  filling      Decimal?                 @db.Decimal(10, 3)
  filling_uom  details_sku_filling_uom?
  mrp          Decimal?                 @db.Decimal(10, 2)
  ean_code     String?                  @unique(map: "ean_code") @db.VarChar(20)
  weight       Decimal?                 @db.Decimal(10, 3)
  weight_uom   details_sku_weight_uom?  @default(g)
  length       Decimal?                 @db.Decimal(8, 2)
  breadth      Decimal?                 @db.Decimal(8, 2)
  height       Decimal?                 @db.Decimal(8, 2)
  hsn_code     String?                  @db.VarChar(20)
  gst_pct      Decimal?                 @db.Decimal(5, 2)
  curr_bom_id  Int?
  last_updated DateTime?                @default(now()) @db.Timestamp(0)
  master_skus  master_skus              @relation(fields: [sku_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "details_sku_ibfk_1")
  master_bom   master_bom?              @relation(fields: [curr_bom_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "details_sku_ibfk_2")

  @@index([curr_bom_id], map: "curr_bom_id")
}

model details_vendor {
  id                   Int                    @id @default(autoincrement())
  vendor_id            Int
  location             String?                @db.VarChar(200)
  status               details_vendor_status? @default(active)
  zone                 String?                @db.VarChar(50)
  registered_name      String?                @db.VarChar(100)
  gst_number           String?                @db.VarChar(20)
  bank_name            String?                @db.VarChar(255)
  ifsc_number          String?                @db.VarChar(11)
  account_number       String?                @db.VarChar(50)
  gst_certificate_key  String?                @db.Text
  cancelled_cheque_key String?                @db.Text
  pan_card_key         String?                @db.Text
  misc_document_key    String?                @db.Text
  master_vendors       master_vendors         @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "details_vendor_ibfk_1")

  @@index([vendor_id], map: "vendor_id")
}

model entity_emails {
  id          Int       @id @default(autoincrement())
  entity_type String    @db.VarChar(10)
  entity_code String    @db.VarChar(50)
  email       String    @db.VarChar(255)
  purpose     String?   @db.VarChar(100)
  created_at  DateTime? @default(now()) @db.Timestamp(0)

  @@index([entity_type, entity_code], map: "idx_entity_emails_lookup")
}

model history_bom {
  id             Int                   @id @default(autoincrement())
  bom_id         Int
  mtrl_type      history_bom_mtrl_type
  mtrl_id        Int
  amount         Decimal?              @db.Decimal(12, 4)
  uom            String?               @db.VarChar(20)
  mtrl_cost      Decimal?              @db.Decimal(12, 4)
  effective_from DateTime?             @db.Date
  effective_till DateTime?             @db.Date
  last_updated   DateTime?             @default(now()) @db.Timestamp(0)
  status         history_bom_status?
  updated_by     Int?
  master_bom     master_bom            @relation(fields: [bom_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "history_bom_ibfk_1")

  @@index([bom_id], map: "bom_id")
}

model history_mrm {
  id             Int       @id @default(autoincrement())
  mfg_id         Int
  mtrl_type      String    @db.VarChar(50)
  mtrl_id        Int
  vendor_id      Int
  rate           Decimal   @db.Decimal(10, 2)
  effective_from DateTime  @db.Date
  effective_to   DateTime? @db.Date
  updated_on     DateTime? @default(now()) @db.DateTime(0)
  status         Boolean?  @default(true)
}

model history_vrm {
  id             Int                   @id @default(autoincrement())
  mtrl_type      history_vrm_mtrl_type
  mtrl_id        Int
  vendor_id      Int?
  rate           Decimal?              @db.Decimal(12, 4)
  effective_from DateTime?             @db.Date
  effective_to   DateTime?             @db.Date
  updated_on     DateTime?             @default(now()) @db.Timestamp(0)
  status         history_vrm_status?
  master_vendors master_vendors?       @relation(fields: [vendor_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "history_vrm_ibfk_1")

  @@index([vendor_id], map: "vendor_id")
}

model bom_artifacts {
  id          Int        @id @default(autoincrement())
  bom_id      Int
  s3_key      String     @db.Text
  file_name   String     @db.VarChar(255)
  uploaded_by Int?
  uploaded_at DateTime   @default(now()) @db.DateTime(0)
  master_bom  master_bom @relation(fields: [bom_id], references: [id], onDelete: Cascade, map: "fk_bom_artifacts_bom")
  users       users?     @relation(fields: [uploaded_by], references: [id], onDelete: SetNull, map: "fk_bom_artifacts_user")

  @@index([bom_id])
}

model master_bom {
  id                      Int                       @id @default(autoincrement())
  bom_code                String                    @db.VarChar(50)
  created_by              Int?
  created_at              DateTime?                 @default(now()) @db.Timestamp(0)
  status                  master_bom_status?        @default(draft)
  sku_id                  Int?
  updated_at              DateTime?                 @db.DateTime(0)
  updated_by              Int?
  bom_artifacts           bom_artifacts[]
  bom_misc                bom_misc[]
  details_bom             details_bom[]
  details_sku             details_sku[]
  history_bom             history_bom[]
  master_skus             master_skus?              @relation(fields: [sku_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bom_sku")
  users                   users?                    @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "master_bom_ibfk_3")
  master_bom_mfg          master_bom_mfg[]
  master_cost_ext_fixed   master_cost_ext_fixed[]
  master_cost_int_dynamic master_cost_int_dynamic[]
  purchase_orders         purchase_orders[]

  @@index([created_by], map: "created_by")
  @@index([sku_id], map: "fk_bom_sku")
}

model master_bom_mfg {
  id               Int         @id @default(autoincrement())
  bom_id           Int
  mfg_id           Int
  status           String      @db.VarChar(50)
  effective_from   DateTime    @db.Date
  effective_to     DateTime?   @db.Date
  created_on       DateTime?   @default(now()) @db.DateTime(0)
  created_by       Int?
  monthly_capacity Int?
  this_month_plan  Int?
  last_batch_date  DateTime?   @db.Date
  remarks          String?     @db.VarChar(255)
  master_bom       master_bom  @relation(fields: [bom_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bomfg_bom")
  users            users?      @relation(fields: [created_by], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bomfg_creator")
  master_mfgs      master_mfgs @relation(fields: [mfg_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_bomfg_mfg")

  @@unique([bom_id, mfg_id], map: "uq_bom_mfg")
  @@index([created_by], map: "fk_bomfg_creator")
  @@index([mfg_id], map: "fk_bomfg_mfg")
}

model master_cost_ext_fixed {
  id                     Int                      @id @default(autoincrement())
  cost_code              String                   @db.VarChar(100)
  bom_id                 Int
